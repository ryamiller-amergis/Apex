# Deployed-smoke config for DEV / STAGING (authenticated read-only).
#
# Copy this file to `.env.e2e` (which is gitignored) and fill in the real values.
# Loaded ONLY by:  npm run test:e2e:deployed
#
# Keeping E2E_BASE_URL out of the root .env is deliberate: the Playwright config
# switches into deployed-target mode whenever E2E_BASE_URL is set, so putting it
# here (instead of root .env) keeps the normal local suite (test:e2e, :smoke, :ui)
# pointed at the local app servers.

# The deployed environment to target (dev shown; swap to the staging slot URL as needed).
E2E_BASE_URL=https://app-scrum-dev.azurewebsites.net

# Dedicated Azure AD (Entra) test account — MFA/Conditional-Access EXEMPT.
# See docs/quality/e2e-test-account-setup.md. Never commit real values.
E2E_TEST_USER=apex-e2e-test@amergis.com
E2E_TEST_PASSWORD=Anyhow-Reappear-Dipping-047
