# Deployed-smoke config for PRODUCTION (UNAUTHENTICATED read-only).
#
# Copy this file to `.env.e2e.prod` (which is gitignored).
# Loaded ONLY by:  npm run test:e2e:deployed:prod
#
# IMPORTANT: prod smoke runs the @prod-safe subset with NO login.
# Do NOT put E2E_TEST_USER / E2E_TEST_PASSWORD here — supplying credentials would
# make the config attempt an authenticated login against production, which we
# intentionally never do. Base URL only.

E2E_BASE_URL=https://app-apex-prd.azurewebsites.net
