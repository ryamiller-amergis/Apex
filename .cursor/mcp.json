{
  "mcpServers": {
    "figma": {
      "type": "http",
      "url": "https://mcp.figma.com/mcp",
      "headers": {
        "X-Figma-Token": "${FIGMA_API_TOKEN}"
      }
    },
    "ado-skills": {
      "type": "http",
      "url": "http://localhost:3001/mcp/ado-skills"
    },
    "sendgrid": {
      "command": "npx",
      "args": ["-y", "sendgrid-mcp"],
      "env": {
        "SENDGRID_API_KEY": "${SENDGRID_API_KEY}"
      }
    }
  }
}
