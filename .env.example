# Azure DevOps Configuration
ADO_ORG=your-organization
ADO_PROJECT=your-project
ADO_PAT=your-personal-access-token
ADO_AREA_PATH=your-area-path

# Azure AD Authentication (see docs/AUTHENTICATION_SETUP.md)
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret
AZURE_REDIRECT_URL=http://localhost:3001/auth/callback
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace-with-random-secret

# Cursor API (agents / Ask Apex). Optional for basic UI smoke tests.
CURSOR_API_KEY=

# Design-system / EXTEND-mode source repo (used to fetch existing-page context for
# design prototypes). Defaults to "MaxView".
MAXVIEW_DS_REPO=MaxView
MAXVIEW_DS_PROJECT=MaxView
# Repo-relative root the screen inventory's "Component / File" paths are listed under.
# The MaxView ClientApp lives below the repo root, so its inventory paths (e.g.
# `components/...`) must be rooted here to resolve to real files. Leave unset when the
# inventory uses repo-root-relative paths.
MAXVIEW_CLIENTAPP_ROOT=/src/Maxim.TimeClock.Web/ClientApp/js

# Server Configuration
PORT=3001

# Polling interval in seconds (default: 30)
POLL_INTERVAL=30

# AWS Bedrock Configuration
AWS_REGION=us-east-1
# Default model used for backlog generation (Features, PBIs, clarifications, etc.)
BEDROCK_MODEL_ID=us.anthropic.claude-haiku-4-5-20251001-v1:0
# Model used specifically for UI/UX mock generation (vision + HTML).
# Falls back to BEDROCK_MODEL_ID if unset. Opus 4.7 produces the best visual
# fidelity for design prototype generation.
BEDROCK_UI_MOCK_MODEL_ID=us.anthropic.claude-opus-4-7
# Max output tokens for UI mock generation. UI mocks can be large HTML+JSON
# documents — Opus 4.7 often needs 20K-30K tokens for detailed prototypes.
BEDROCK_UI_MOCK_MAX_TOKENS=32000

# PostgreSQL Database
# Format: postgresql://<user>:<password>@<host>:<port>/<database>?sslmode=require
# - Production: set automatically by Terraform (injected into App Service app_settings)
# - Local dev: point to a local PostgreSQL instance (conventional DB name: aipilot)
#   or use a tunnel / shared cloud DATABASE_URL from the team env files
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/aipilot

# Agent token signing secret — used to mint short-lived HMAC tokens that
# authorize the Cursor agent to fetch the mock HTML and post the resulting
# Figma URL back. REQUIRED in production (otherwise the server falls back to
# an insecure dev-only secret and logs a warning). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BACKLOG_AGENT_SIGNING_SECRET=replace-with-32-byte-random-hex

# Azure Application Insights
# Set automatically by Terraform in production; leave empty for local dev.
APPLICATIONINSIGHTS_CONNECTION_STRING=

# SendGrid (Twilio) — used by the sendgrid MCP server for email analytics.
# Generate a read-only key at https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=

# MaxView timecard-debug MCP (read-only). When configured AND the `maxview-mcp`
# feature flag is enabled for the user/project, the chat agent gets the MaxView
# timecard tools via the Apex-hosted proxy at /mcp/maxview. Apex logs in with the
# service account below and auto-refreshes the RS256 app token. The service
# account must have the MaxView-side `mcp-server` feature flag enabled.
MAXVIEW_MCP_BASE_URL=
MAXVIEW_MCP_USERNAME=
MAXVIEW_MCP_PASSWORD=
# Optional: supply a pre-minted bearer token instead of username/password
# (bypasses the login flow; note the token expires and is not auto-refreshed).
MAXVIEW_MCP_TOKEN=
# Optional: set to "true" to skip TLS cert validation for a local self-signed
# MaxView dev server (e.g. https://localhost:5001). NEVER enable in production.
MAXVIEW_MCP_INSECURE_TLS=
